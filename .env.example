# Gmail Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Email Recipients (comma-separated for multiple)
EMAIL_TO=recipient@example.com

# Schedule (cron format - default: 9 AM daily)
CRON_SCHEDULE=0 9 * * *

# Content Configuration
MAX_LAUNCHES=5
MAX_TRENDS=5
MIN_UPVOTES=50
MAX_EMERGING_COMPANIES=5
MAX_ACCELERATING_COMPANIES=5
MAX_PEOPLE_TO_MEET=3

# Optional GitHub API token for richer company/contributor profiles
GITHUB_TOKEN=

# Optional Product Hunt API token
PRODUCT_HUNT_TOKEN=

# Optional Twitter API key (from twitterapi.io)
# Sign up at https://twitterapi.io - Free trial: $0.10 credit
# Pricing: $0.15 per 1,000 tweets (much cheaper than official Twitter API)
TWITTER_API_KEY=

# Email threading + storage
EMAIL_SUBJECT=
SNAPSHOT_FILE=.data/daily-snapshots.json
